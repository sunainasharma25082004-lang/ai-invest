# Frontend + Admin service (Render Web Service #1)
# Set these in Render → Environment BEFORE deploy (build time vars)
VITE_API_URL=https://YOUR-API-NAME.onrender.com/api

# API service (Render Web Service #2) — set in Render Environment
# SERVE_STATIC=false
# NODE_ENV=production
# JWT_SECRET=your-long-random-secret
# MONGODB_URI=mongodb+srv://...
# ADMIN_EMAIL=admin@yourmail.com
# ADMIN_PASSWORD=your-strong-password
# CLIENT_ORIGIN=https://YOUR-FRONTEND-NAME.onrender.com