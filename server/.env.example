PORT=3001
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-secret
CLIENT_ORIGIN=http://localhost:5173
ADMIN_ORIGIN=http://localhost:5174
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/ai-invest?appName=Cluster0

# Render 3-service production (recommended):
# SERVE_STATIC=false
# NODE_ENV=production
# JWT_SECRET=...
# MONGODB_URI=mongodb+srv://...
# CLIENT_ORIGIN=https://investindigitalcurrency.com
# ADMIN_ORIGIN=https://ai-admin-dd0z.onrender.com
# ALLOWED_ORIGINS=https://investindigitalcurrency.com,https://www.investindigitalcurrency.com,https://ai-admin-dd0z.onrender.com
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=your-strong-password
#
# Services:
# - Frontend: investindigitalcurrency.com (static, build: npm run build:render:frontend)
# - API: ai-invest-api-bznc.onrender.com (build: npm run build:render:api, start: npm start)
# - Admin: ai-admin-dd0z.onrender.com (static, build: npm run build:render:admin)
#
# MongoDB Atlas: Network Access → Add IP → "Allow access from anywhere" (0.0.0.0/0)