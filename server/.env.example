PORT=3001
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-secret
CLIENT_ORIGIN=http://localhost:5173
ADMIN_ORIGIN=http://localhost:5174
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/ai-invest?appName=Cluster0

# VPS production (Nginx serves static files; API only on Node):
# SERVE_STATIC=false
# CLIENT_ORIGIN=https://example.com
# ADMIN_ORIGIN=https://admin.example.com

# Render production (set in Render Dashboard → Environment):
# NODE_ENV=production          (set automatically by render.yaml)
# JWT_SECRET=...               (auto-generated by render.yaml)
# MONGODB_URI=mongodb+srv://... (required — paste your Atlas connection string)
# CLIENT_ORIGIN=https://your-app-name.onrender.com (optional — RENDER_EXTERNAL_URL is used if omitted)
#
# MongoDB Atlas: Network Access → Add IP → "Allow access from anywhere" (0.0.0.0/0)