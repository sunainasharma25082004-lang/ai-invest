PORT=3001
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-secret
CLIENT_ORIGIN=http://localhost:5173
ADMIN_ORIGIN=http://localhost:5174
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/ai-invest?appName=Cluster0

# VPS production (Nginx serves static files; API only on Node):
# SERVE_STATIC=false
# CLIENT_ORIGIN=https://example.com
# ADMIN_ORIGIN=https://admin.example.com

# Render production (single deploy — website + admin on same service):
# NODE_ENV=production
# JWT_SECRET=...
# MONGODB_URI=mongodb+srv://...
# CLIENT_ORIGIN=https://investindigitalcurrency.com
# ALLOWED_ORIGINS=https://investindigitalcurrency.com,https://www.investindigitalcurrency.com,https://ai-admin-dd0z.onrender.com
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=your-strong-password
#
# Custom domain on Render:
# 1. Render Dashboard → your service → Settings → Custom Domains → Add yourdomain.com
# 2. At your domain registrar (GoDaddy, Namecheap, etc.) add the DNS record Render shows
# 3. Set CLIENT_ORIGIN=https://yourdomain.com in Environment
# 4. Website: https://yourdomain.com  |  Admin: https://yourdomain.com/admin/
#
# MongoDB Atlas: Network Access → Add IP → "Allow access from anywhere" (0.0.0.0/0)